# Copy this file to .env and fill in your own values.
# NEVER commit .env to Git — it's in .gitignore.

# === RapidAPI (Booking.com via Tipsters) ===
# Get your key at https://rapidapi.com → Booking.com by Tipsters CO → Subscribe (Free plan)
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=booking-com.p.rapidapi.com

# === JWT Authentication ===
# Generate a strong random secret with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace_with_a_random_string_at_least_32_chars_long

# === Database ===
DATABASE_URL=sqlite:///./travel_booking.db